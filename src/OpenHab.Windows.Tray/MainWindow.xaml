<Window
    x:Class="OpenHab.Windows.Tray.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mainui="using:OpenHab.Windows.Tray.MainUi"
    Title="openHAB">
    <Grid x:Name="ShellRoot" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <MenuFlyout x:Name="SitemapMenuFlyout" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarRoot"
              Grid.Row="0"
              Padding="8,0,138,0"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="SidebarCollapseButton"
                    Width="34"
                    Height="30"
                    Padding="0"
                    Click="SidebarCollapseButton_Click"
                    ToolTipService.ToolTip="Collapse navigation"
                    AutomationProperties.Name="Collapse navigation">
                <FontIcon x:Name="SidebarCollapseIcon" Glyph="&#xE96F;" FontSize="14" />
            </Button>

            <Grid x:Name="TitleBarDragRegion"
                  Grid.Column="1"
                  Background="Transparent" />

            <Button x:Name="ToggleSitemapButton"
                    Grid.Column="2"
                    Width="34"
                    Height="30"
                    Padding="0"
                    Click="ToggleSitemapButton_Click"
                    ToolTipService.ToolTip="Show sitemap"
                    AutomationProperties.Name="Show sitemap">
                <FontIcon x:Name="ToggleSitemapIcon" Glyph="&#xF246;" FontSize="14" />
            </Button>
        </Grid>

        <Grid x:Name="BodyRoot"
              Grid.Row="1"
              ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="SitemapPaneColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarRoot"
                    Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid x:Name="SidebarLayoutRoot" Padding="12,18,12,12" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="8">
                        <StackPanel x:Name="SidebarBrandPanel"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Margin="4,0,0,14">
                            <Image Width="28" Height="28">
                                <Image.Source>
                                    <SvgImageSource UriSource="ms-appx:///Assets/openhab-icon.svg" />
                                </Image.Source>
                            </Image>
                            <StackPanel x:Name="SidebarBrandTextPanel">
                                <TextBlock Text="openHAB" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="Windows companion" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <Grid x:Name="HomeNavRow" ColumnSpacing="0" Height="34">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="HomeNavButton" Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinWidth="0" Height="34" Padding="10,0,10,0" Click="HomeNavButton_Click" ToolTipService.ToolTip="Home" AutomationProperties.Name="Home">
                                <StackPanel x:Name="HomeNavContent" Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE80F;" FontSize="14" />
                                    <TextBlock x:Name="HomeNavText" Text="Home" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="HomePagesToggleButton" Grid.Column="1" Width="34" MinWidth="0" Height="34" Padding="0" Click="HomePagesToggleButton_Click" ToolTipService.ToolTip="Show Main UI pages" AutomationProperties.Name="Show Main UI pages">
                                <FontIcon x:Name="MainUiPagesChevron" Glyph="&#xE70D;" FontSize="12" />
                            </Button>
                        </Grid>

                        <StackPanel x:Name="MainUiPagesList" Spacing="6" Margin="28,0,0,2" />

                        <Button x:Name="NotificationsNavButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinWidth="0" Height="34" Padding="10,0,10,0" Click="NotificationsNavButton_Click" ToolTipService.ToolTip="Notifications" AutomationProperties.Name="Notifications">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE7F4;" FontSize="14" />
                                <TextBlock x:Name="NotificationsNavText" Text="Notifications" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="SettingsNavButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinWidth="0" Height="34" Padding="10,0,10,0" Click="SettingsNavButton_Click" ToolTipService.ToolTip="Settings" AutomationProperties.Name="Settings">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE713;" FontSize="14" />
                                <TextBlock x:Name="SettingsNavText" Text="Settings" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel x:Name="SidebarConnectionPanel" Grid.Row="2" Spacing="2">
                        <TextBlock x:Name="ShellConnectionText" Text="Connecting..." Opacity="0.8" />
                        <TextBlock Text="to openHAB server" Opacity="0.55" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock x:Name="ShellStatusText"
                                   Visibility="Collapsed"
                                   Opacity="0.8"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="CenterContentHost"
                  Grid.Column="1"
                  Margin="12,10,12,0">
                <mainui:MainUiWebViewHost x:Name="MainUiHost" />
            </Grid>

            <Border x:Name="SitemapContentRoot"
                    Grid.Column="2"
                    Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="12"
                    SizeChanged="SitemapContentRoot_SizeChanged">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="SitemapPanelHeader" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="SitemapPickerButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Click="SitemapPickerButton_Click"
                                ToolTipService.ToolTip="Choose sitemap"
                                AutomationProperties.Name="Choose sitemap">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Name="SitemapPickerText" Text="Sitemap" TextTrimming="CharacterEllipsis" />
                                <FontIcon Glyph="&#xE70D;" FontSize="12" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="BackButton"
                                Grid.Column="1"
                                Width="34"
                                Height="34"
                                Padding="0"
                                Click="NavigateBack_Click"
                                ToolTipService.ToolTip="Back"
                                Visibility="Collapsed">
                            <FontIcon Glyph="&#xE72B;" FontSize="13" />
                        </Button>

                        <Button x:Name="RefreshSitemapButton"
                                Grid.Column="2"
                                Width="34"
                                Height="34"
                                Padding="0"
                                Click="RefreshButton_Click"
                                ToolTipService.ToolTip="Refresh sitemap"
                                AutomationProperties.Name="Refresh sitemap">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid x:Name="SitemapPageSlotA" Background="Transparent">
                            <ScrollViewer>
                                <StackPanel x:Name="SitemapRows" Spacing="4" />
                            </ScrollViewer>
                        </Grid>
                        <Grid x:Name="SitemapPageSlotB" Visibility="Collapsed" Background="Transparent">
                            <ScrollViewer>
                                <StackPanel x:Name="SitemapRowsB" Spacing="4" />
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
