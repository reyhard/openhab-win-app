<Window
    x:Class="OpenHab.Windows.Tray.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="openHAB">
    <Grid Margin="20" RowSpacing="12" ColumnSpacing="20">
        <Grid.Resources>
            <MenuFlyout x:Name="SitemapMenuFlyout" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.ColumnSpan="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton"
                    Width="34"
                    Height="34"
                    Padding="0"
                    Click="NavigateBack_Click"
                    ToolTipService.ToolTip="Back"
                    Visibility="Collapsed"
                    VerticalAlignment="Top">
                <FontIcon Glyph="&#xE72B;" FontSize="13" />
            </Button>

            <Image Width="22"
                   Height="22"
                   Grid.Column="1"
                   VerticalAlignment="Top"
                   Margin="0,2,0,0">
                <Image.Source>
                    <SvgImageSource UriSource="ms-appx:///Assets/openhab-icon.svg" />
                </Image.Source>
            </Image>

            <StackPanel x:Name="SitemapHeaderArea"
                        Grid.Column="2"
                        Spacing="4"
                        Background="Transparent"
                        HorizontalAlignment="Left"
                        IsTapEnabled="True"
                        Tapped="SitemapHeaderArea_Tapped">
                <TextBlock x:Name="TitleText"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="StatusText"
                           Opacity="0.6"
                           Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>

            <Button Grid.Column="3"
                    VerticalAlignment="Center"
                    Click="RefreshButton_Click"
                    ToolTipService.ToolTip="Refresh"
                    Width="36" Height="36" Padding="4">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
        </Grid>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Height="1"
                Margin="0,4,0,0"
                Background="{ThemeResource CardStrokeColorDefaultBrush}"
                Opacity="0.3" />

        <BreadcrumbBar Grid.Row="2"
                       Grid.ColumnSpan="2"
                       x:Name="BreadcrumbBar"
                       ItemClicked="BreadcrumbBar_ItemClicked"
                       Margin="0,0,0,2">
            <BreadcrumbBar.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Label}"
                               FontFamily="{Binding FontFamily}"
                               FontSize="{Binding FontSize}" />
                </DataTemplate>
            </BreadcrumbBar.ItemTemplate>
        </BreadcrumbBar>

        <Border Grid.Row="3"
                Grid.Column="0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <ScrollViewer>
                <StackPanel x:Name="SitemapRows" Spacing="4" />
            </ScrollViewer>
        </Border>

        <Pivot Grid.Row="3" Grid.Column="1" x:Name="SidePanelPivot">
            <PivotItem Header="Notifications">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NotificationsTitle"
                                       Text="Notifications"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <Border Grid.Column="1"
                                    x:Name="UnreadBadge"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="10"
                                    Padding="6,2"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="UnreadCountText"
                                           FontSize="11" />
                            </Border>
                            <Button Grid.Column="2"
                                    x:Name="DismissAllButton"
                                    Content="Dismiss all"
                                    Click="DismissAllButton_Click" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <ScrollViewer>
                                <StackPanel x:Name="NotificationRows" Spacing="4" />
                            </ScrollViewer>
                            <TextBlock x:Name="EmptyNotificationsText"
                                       Text="No notifications"
                                       Opacity="0.5"
                                       HorizontalAlignment="Center"
                                       Margin="0,40,0,0"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Grid>
                </Border>
            </PivotItem>

            <PivotItem Header="Settings">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <ScrollViewer>
                        <StackPanel Spacing="12">
                            <TextBlock Text="Settings"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <ComboBox x:Name="SkinCombo"
                                      Header="Skin"
                                      SelectionChanged="SkinCombo_SelectionChanged" />
                            <ComboBox x:Name="EndpointModeCombo"
                                      Header="Endpoint mode"
                                      SelectionChanged="EndpointModeCombo_SelectionChanged" />
                            <TextBox x:Name="LocalEndpointText"
                                     Header="Local endpoint"
                                     LostFocus="EndpointText_LostFocus" />
                            <TextBox x:Name="CloudEndpointText"
                                     Header="Cloud endpoint"
                                     LostFocus="EndpointText_LostFocus" />
                            <PasswordBox x:Name="LocalTokenBox"
                                         Header="Local API token"
                                         PlaceholderText="Enter token (optional)"
                                         GotFocus="TokenBox_GotFocus"
                                         PasswordChanged="TokenBox_PasswordChanged"
                                         LostFocus="TokenBox_LostFocus"
                                         Tag="Local" />
                            <TextBox x:Name="CloudUserNameText"
                                     Header="Cloud email / username"
                                     PlaceholderText="Enter myopenHAB email"
                                     TextChanged="CloudUserNameText_TextChanged"
                                     LostFocus="CloudCredentials_LostFocus" />
                            <PasswordBox x:Name="CloudPasswordBox"
                                         Header="Cloud password"
                                         PlaceholderText="Enter myopenHAB password"
                                         PasswordChanged="CloudPasswordBox_PasswordChanged"
                                         LostFocus="CloudCredentials_LostFocus" />
                            <ToggleSwitch x:Name="FollowThemeToggle"
                                          Header="Follow Windows color scheme"
                                          OnContent="On" OffContent="Off"
                                          Toggled="FollowThemeToggle_Toggled" />
                            <ToggleSwitch x:Name="UseWin11IconsToggle"
                                          Header="Use Windows 11 style icons"
                                          OnContent="On" OffContent="Off"
                                          Toggled="UseWin11IconsToggle_Toggled" />
                            <NumberBox x:Name="FlyoutWidthBox"
                                       Header="Flyout width (px)"
                                       Minimum="360"
                                       Maximum="900"
                                       SmallChange="10"
                                       SpinButtonPlacementMode="Inline"
                                       ValueChanged="FlyoutWidthBox_ValueChanged" />
                            <Button x:Name="ViewLogsButton"
                                    Content="View diagnostic logs"
                                    Margin="0,8,0,0"
                                    Click="ViewLogsButton_Click" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </PivotItem>
        </Pivot>
    </Grid>
</Window>
