<Window
    x:Class="OpenHab.Windows.Tray.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="openHAB">
    <Grid Margin="20" RowSpacing="12" ColumnSpacing="20">
        <Grid.Resources>
            <MenuFlyout x:Name="SitemapMenuFlyout" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.ColumnSpan="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton"
                    Width="34"
                    Height="34"
                    Padding="0"
                    Click="NavigateBack_Click"
                    ToolTipService.ToolTip="Back"
                    Visibility="Collapsed"
                    VerticalAlignment="Top">
                <FontIcon Glyph="&#xE72B;" FontSize="13" />
            </Button>

            <Image Width="22"
                   Height="22"
                   Grid.Column="1"
                   VerticalAlignment="Top"
                   Margin="0,2,0,0">
                <Image.Source>
                    <SvgImageSource UriSource="ms-appx:///Assets/openhab-icon.svg" />
                </Image.Source>
            </Image>

            <StackPanel x:Name="SitemapHeaderArea"
                        Grid.Column="2"
                        Spacing="4"
                        Background="Transparent"
                        HorizontalAlignment="Left"
                        IsTapEnabled="True"
                        Tapped="SitemapHeaderArea_Tapped">
                <TextBlock x:Name="TitleText"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="StatusText"
                           Opacity="0.6"
                           Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>

            <Button Grid.Column="3"
                    VerticalAlignment="Center"
                    Click="RefreshButton_Click"
                    ToolTipService.ToolTip="Refresh"
                    Width="36" Height="36" Padding="4">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
        </Grid>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Height="1"
                Margin="0,4,0,0"
                Background="{ThemeResource CardStrokeColorDefaultBrush}"
                Opacity="0.3" />

        <Border x:Name="SitemapContentRoot"
                Grid.Row="2"
                Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <!-- Dual-slot layout for simultaneous page transitions.
                 Slot A is the active rendering surface; Slot B is the
                 off-screen peer populated before crossfade animation. -->
            <Grid>
                <Grid x:Name="SitemapPageSlotA"
                      Background="Transparent">
                    <ScrollViewer>
                        <StackPanel x:Name="SitemapRows" Spacing="4" />
                    </ScrollViewer>
                </Grid>
                <Grid x:Name="SitemapPageSlotB"
                      Visibility="Collapsed"
                      Background="Transparent">
                    <ScrollViewer>
                        <StackPanel x:Name="SitemapRowsB" Spacing="4" />
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <Grid x:Name="CenterContentHost" Grid.Row="2" Grid.Column="1" />
    </Grid>
</Window>
