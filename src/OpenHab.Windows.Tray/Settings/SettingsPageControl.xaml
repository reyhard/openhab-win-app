<UserControl
    x:Class="OpenHab.Windows.Tray.Settings.SettingsPageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid>
                <StackPanel Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Button x:Name="SettingsBreadcrumbRootButton" Content="Settings" Padding="0" BorderThickness="0" Background="Transparent" FontSize="18" Opacity="0.65" Visibility="Collapsed" Click="SettingsBreadcrumbRootButton_Click" />
                        <FontIcon x:Name="SettingsBreadcrumbChevron" Glyph="&#xE76C;" FontSize="12" Opacity="0.65" Visibility="Collapsed" VerticalAlignment="Center" />
                        <TextBlock x:Name="SettingsTitleText" Text="Settings" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBlock x:Name="SettingsSubtitleText" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Grid>
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="SettingsContent" Spacing="8" HorizontalAlignment="Stretch" />
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
